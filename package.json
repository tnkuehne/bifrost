{
  "name": "bifrost",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "vite build",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "dev": "wrangler dev --tunnel",
    "cf-typegen": "wrangler types",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src --tsconfig tsconfig.json --deny-warnings",
    "lint:fix": "oxlint src --tsconfig tsconfig.json --fix",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "hono": "^4.12.14",
    "runed": "^0.37.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.59.0",
    "qrcode": "^1.5.4",
    "svelte": "^5.55.10",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.2",
    "vite": "^8.0.14",
    "wrangler": "^4.95.0"
  }
}
